{
  "manifest_version": 3,
  "name": "Screen OCR Scanner",
  "description": "Quét và nhận diện văn bản (OCR) từ màn hình hỗ trợ Tiếng Anh và Tiếng Việt.",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen"
  ],
  "action": {
    "default_title": "Quét vùng màn hình"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
